APP_MODE=demo

# Use separate API keys for Spot Testnet in demo mode and never enable withdrawal permissions.
# GitHub Actions can read the same variable names from repository or environment secrets.
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key
BINANCE_RECV_WINDOW=5000

# Optional Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading universe.
SYMBOLS=BTCUSDT,ETHUSDT
TIMEFRAME=15m
CANDLE_LIMIT=120
FAST_EMA_PERIOD=20
SLOW_EMA_PERIOD=50

# Risk controls.
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04
RISK_PER_TRADE_PCT=0.01
MAX_POSITION_PCT=0.10
MAX_OPEN_POSITIONS_TOTAL=2
MAX_OPEN_POSITIONS_PER_SYMBOL=1
DAILY_LOSS_LIMIT_PCT=0.03
MAX_CONSECUTIVE_LOSSES=3

# Runtime behavior.
LOOP_INTERVAL_SECONDS=30
ORDER_CONFIRM_TIMEOUT_SECONDS=15
REQUEST_TIMEOUT_SECONDS=15
STALE_DATA_MULTIPLIER=2
QUOTE_ASSET=USDT
# Set to true for a single cycle run, for example in GitHub Actions.
RUN_ONCE=false
